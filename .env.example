# ─── LLM Provider: "openai" | "azure" | "self_hosted" ───
LLM_PROVIDER=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
SELF_HOSTED_LLM_URL=
SELF_HOSTED_MODEL_NAME=
DEFAULT_MODEL=

# ─── Confluence (팀 계정) ───
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_USER_EMAIL=
CONFLUENCE_SPACE_KEY=OnRamp
CONFLUENCE_TIMEZONE=Asia/Seoul

# ─── GitHub (멀티소스 적재 — README·docs·이슈/PR) ───
GITHUB_TOKEN=""

# ─── 로컬 DB (docker compose 기본값) ───
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=onramp
OPENSEARCH_HOST=localhost
# BM25/하이브리드는 별개 플래그: BM25는 '적재 시 색인', HYBRID는 '검색 시 융합'.
BM25_SEARCH_ENABLED=true        # 적재 시 OpenSearch 청크 BM25 색인
HYBRID_SEARCH_ENABLED=true      # 검색 시 dense(Qdrant)+BM25(OpenSearch) RRF 융합 (off면 dense-only)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onramp
REDIS_URL=redis://localhost:6379/0
REDIS_OUTBOX_BATCH_SIZE=100
REDIS_OUTBOX_POLL_INTERVAL_MS=500
REDIS_STREAM_BLOCK_MS=5000
REDIS_STREAM_READ_COUNT=10
REDIS_STREAM_RECLAIM_IDLE_MS=300000
STT_REDIS_URL=
STT_CONSUMER_GROUP_SUFFIX=

# ─── STT 내부 API / 보고서 worker ───
STT_SERVICE_BASE_URL=http://localhost:8001
STT_SERVICE_TOKEN=
STT_RESULT_TIMEOUT_SECONDS=30
REPORT_WORKER_POLL_INTERVAL_MS=1000
REPORT_WORKER_PROCESSING_TIMEOUT_SECONDS=300
REPORT_WORKER_MAX_RETRIES=3
REPORT_WINDOW_MAX_CHARS=12000
REPORT_WINDOW_OVERLAP_CHARS=500
REPORT_MERGE_BATCH_SIZE=4

# ─── Authentication ───
# HS256 secret은 32바이트 이상의 임의 문자열을 사용한다.
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=onramp-api
AUTH_ENABLE_SLACK_LOGIN=false
AUTH_SESSION_TTL_SECONDS=3600
AUTH_STATE_TTL_SECONDS=600
AUTH_SLACK_CLIENT_ID=
AUTH_SLACK_CLIENT_SECRET=
AUTH_SLACK_REDIRECT_URI=
AUTH_SLACK_AUTHORIZE_URL=https://slack.com/openid/connect/authorize
AUTH_SLACK_TOKEN_URL=https://slack.com/api/openid.connect.token
AUTH_SLACK_ISSUER=https://slack.com
# 외부 식별자 -> 내부 tenant_id 매핑.
# 예: {"slack:T12345":"tenant1-onramp","entra:abc-company-prod":"tenant1-onramp"}
TENANT_REGISTRY={}

# ─── Object Storage (S3/MinIO 호환) ───
STORAGE_BUCKET=onramp-stt
STORAGE_ENDPOINT_URL=
# 브라우저에 반환할 presigned URL endpoint. 로컬 Docker에서는 http://localhost:9000
STORAGE_PUBLIC_ENDPOINT_URL=
STORAGE_REGION=ap-northeast-2
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_UPLOAD_EXPIRES_SECONDS=900

# ─── 리랭커 (#60, opt-in · 기본 torch) ───
# ONNX(int8) 백엔드 사용 시: make setup-reranker-onnx 후 아래 주석 해제.
# RERANKER_BACKEND=onnx
# RERANKER_ONNX_DIR=models/bge-reranker-onnx-int8
# RERANKER_ONNX_FILE=model_quantized.onnx

# ─── 앱 ───
DEBUG=true
