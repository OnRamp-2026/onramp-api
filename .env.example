# ─── 필수 ───
OPENAI_API_KEY=sk-실제키

# ─── Confluence (팀 계정) ───
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_API_TOKEN=실제토큰
CONFLUENCE_USER_EMAIL=your-email@company.com

# ─── 로컬 DB (docker compose 기본값) ───
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=onramp
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onramp
REDIS_URL=redis://localhost:6379/0

# ─── 선택 (Azure LLM 쓸 때만) ───
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ─── 앱 ───
DEFAULT_MODEL=gpt-4o-mini
DEBUG=true